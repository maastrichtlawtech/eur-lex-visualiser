# API listen port
PORT=3000

# Shared cache directory for FMX files (*.xml, *.zip) and parsed HTML (*.parsed.json.gz).
# For Railway with a mounted volume, point this at the mount path, e.g. /data/law-cache
# Also accepts the legacy FMX_DIR variable as a fallback.
CACHE_DIR=./law-cache

# Per-IP request cap for the 15-minute rate-limit window
RATE_LIMIT_MAX=100

# Max FMX cache size in MB before oldest FMX files are evicted
STORAGE_LIMIT_MB=500

# Max HTML cache size in MB before oldest parsed HTML files are evicted
HTML_CACHE_LIMIT_MB=200

# Optional override for the search cache JSON path
SEARCH_CACHE_PATH=./search/data/search-cache.json
