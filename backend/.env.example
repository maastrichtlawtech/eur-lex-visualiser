# API listen port
PORT=3000

# Directory for cached FMX/XML/ZIP downloads.
# For Railway with a mounted volume, point this at the mount path, e.g. /data/fmx-downloads
FMX_DIR=./fmx-downloads

# Per-IP request cap for the 15-minute rate-limit window
RATE_LIMIT_MAX=100

# Max FMX cache size in MB before oldest files are evicted
STORAGE_LIMIT_MB=500

# Optional override for the search cache JSON path
SEARCH_CACHE_PATH=./search/data/search-cache.json
