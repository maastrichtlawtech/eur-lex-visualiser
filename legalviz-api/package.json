{
  "name": "eur-lex-fmx-api",
  "version": "1.0.0",
  "description": "REST API for serving EU law FMX files",
  "main": "server.js",
  "bin": {
    "eurlex": "./bin/eurlex.js",
    "parse-fmx": "./bin/parse-fmx.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:search-cache": "node search/search-build.js",
